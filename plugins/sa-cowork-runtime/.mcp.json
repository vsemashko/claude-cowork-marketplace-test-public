{
  "mcpServers": {
    "cowork-secret-plugin-option": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/skills/sa-cowork-secret-probe/scripts/server.sh",
      "env": {
        "SA_COWORK_PROBE_NAME": "cowork-secret-plugin-option",
        "SA_COWORK_PROBE_MODE": "plugin-option"
      }
    },
    "cowork-secret-file-env": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/skills/sa-cowork-secret-probe/scripts/server.sh",
      "env": {
        "SA_COWORK_PROBE_NAME": "cowork-secret-file-env",
        "SA_COWORK_PROBE_MODE": "file-env",
        "SA_COWORK_SECRET_FILE": "${CLAUDE_PLUGIN_DATA}/secret-smoke/persisted-secret.txt"
      }
    },
    "cowork-remote-oauth-kernel": {
      "type": "http",
      "url": "https://mcp.onkernel.com/mcp"
    },
    "cowork-secret-user-config": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/skills/sa-cowork-secret-probe/scripts/server.sh",
      "env": {
        "SA_COWORK_PROBE_NAME": "cowork-secret-user-config",
        "SA_COWORK_PROBE_MODE": "user-config",
        "SA_COWORK_MAPPED_LABEL": "${user_config.smoke_label:}",
        "SA_COWORK_MAPPED_TOKEN": "${user_config.smoke_token:}"
      }
    },
    "cowork-secret-file": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/skills/sa-cowork-secret-probe/scripts/server.sh",
      "env": {
        "SA_COWORK_PROBE_NAME": "cowork-secret-file",
        "SA_COWORK_PROBE_MODE": "file"
      }
    }
  }
}
