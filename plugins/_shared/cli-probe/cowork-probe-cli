#!/usr/bin/env sh
set -eu

label="${PROBE_LABEL:-unset}"
endpoint="${PROBE_ENDPOINT:-unset}"
strategy="${PROBE_STRATEGY:-unknown}"
token="${PROBE_TOKEN:-}"
token_length=0

if [ -n "$token" ]; then
  token_length=$(printf "%s" "$token" | wc -c | tr -d ' ')
fi

printf 'probe_name=%s\n' 'cowork-probe-cli'
printf 'strategy=%s\n' "$strategy"
printf 'label=%s\n' "$label"
printf 'endpoint=%s\n' "$endpoint"
printf 'token_length=%s\n' "$token_length"
