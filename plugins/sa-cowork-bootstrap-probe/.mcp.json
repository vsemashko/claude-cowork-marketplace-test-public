{
  "mcpServers": {
    "cowork-bootstrap-probe": {
      "type": "stdio",
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-servers/bootstrap-probe-server.mjs"],
      "env": {
        "PROBE_STRATEGY": "bootstrap",
        "PROBE_PLUGIN_NAME": "sa-cowork-bootstrap-probe",
        "PROBE_PLUGIN_VERSION": "1.0.0",
        "PROBE_PLUGIN_ROOT": "${CLAUDE_PLUGIN_ROOT}",
        "PROBE_PLUGIN_DATA": "${CLAUDE_PLUGIN_DATA}",
        "PROBE_COMMAND_NAME": "cowork-probe-cli",
        "PROBE_LABEL": "${user_config.probe_label}",
        "PROBE_ENDPOINT": "${user_config.probe_endpoint}",
        "PROBE_TOKEN": "${user_config.probe_token}",
        "PROBE_CACHE_NAMESPACE": "bootstrap",
        "PROBE_BUNDLED_ASSET": "${CLAUDE_PLUGIN_ROOT}/../_shared/cli-probe/cowork-probe-cli"
      },
      "_meta": {
        "name": "cowork-bootstrap-probe",
        "description": "Claude-style mirror for the bootstrap strategy with shared probe tools.",
        "enabled": true
      }
    }
  }
}
