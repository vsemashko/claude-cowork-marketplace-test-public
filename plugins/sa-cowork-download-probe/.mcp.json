{
  "mcpServers": {
    "cowork-download-probe": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-servers/download-probe-server.mjs"],
      "env": {
        "PROBE_STRATEGY": "download",
        "PROBE_PLUGIN_NAME": "sa-cowork-download-probe",
        "PROBE_PLUGIN_VERSION": "1.0.0",
        "PROBE_PLUGIN_ROOT": "${CLAUDE_PLUGIN_ROOT}",
        "PROBE_PLUGIN_DATA": "${CLAUDE_PLUGIN_DATA}",
        "PROBE_COMMAND_NAME": "cowork-probe-cli",
        "PROBE_LABEL": "${user_config.probe_label}",
        "PROBE_ENDPOINT": "${user_config.probe_endpoint}",
        "PROBE_TOKEN": "${user_config.probe_token}",
        "PROBE_CACHE_NAMESPACE": "download",
        "PROBE_DOWNLOAD_URL": "https://raw.githubusercontent.com/vsemashko/claude-cowork-marketplace-test-public/main/plugins/_shared/cli-probe/cowork-probe-cli"
      },
      "_meta": {
        "name": "cowork-download-probe",
        "description": "Claude-style mirror for the download strategy with shared probe tools.",
        "enabled": true
      }
    }
  }
}
